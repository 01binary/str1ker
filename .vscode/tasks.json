{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "catkin_make -C ~/catkin_ws",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Arduino: Install CLI",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "if command -v arduino-cli >/dev/null 2>&1; then arduino-cli version; else curl -fsSL https://raw.githubusercontent.com/arduino/arduino-cli/master/install.sh | BINDIR=\"$HOME/.local/bin\" sh && \"$HOME/.local/bin/arduino-cli\" version; fi"
            ],
            "problemMatcher": []
        },
        {
            "label": "Arduino: Update Indexes",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "--config-file",
                "${workspaceFolder}/.vscode/arduino-cli.yaml",
                "core",
                "update-index"
            ],
            "dependsOn": "Arduino: Install CLI",
            "problemMatcher": []
        },
        {
            "label": "Arduino: Install Teensy Core",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "--config-file",
                "${workspaceFolder}/.vscode/arduino-cli.yaml",
                "core",
                "install",
                "teensy:avr"
            ],
            "dependsOn": "Arduino: Update Indexes",
            "problemMatcher": []
        },
        {
            "label": "Arduino: Compile Arm",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "--config-file",
                "${workspaceFolder}/.vscode/arduino-cli.yaml",
                "compile",
                "--fqbn",
                "teensy:avr:teensy40:usb=serial,speed=600,opt=o2std,keys=en-us",
                "--libraries",
                "${env:HOME}/Arduino/libraries",
                "--build-path",
                "${workspaceFolder}/.arduino/build/arm",
                "${workspaceFolder}/src/drivers/arm"
            ],
            "dependsOn": "Arduino: Install Teensy Core",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Arduino: Upload Arm",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "--config-file",
                "${workspaceFolder}/.vscode/arduino-cli.yaml",
                "upload",
                "-p",
                "/dev/ttyACM0",
                "--fqbn",
                "teensy:avr:teensy40:usb=serial,speed=600,opt=o2std,keys=en-us",
                "${workspaceFolder}/src/drivers/arm"
            ],
            "dependsOn": "Arduino: Compile Arm",
            "problemMatcher": []
        },
        {
            "label": "Arduino: Compile Body",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "--config-file",
                "${workspaceFolder}/.vscode/arduino-cli.yaml",
                "compile",
                "--fqbn",
                "teensy:avr:teensy40:usb=serial,speed=600,opt=o2std,keys=en-us",
                "--libraries",
                "${env:HOME}/Arduino/libraries",
                "--build-path",
                "${workspaceFolder}/.arduino/build/body",
                "${workspaceFolder}/src/drivers/body"
            ],
            "dependsOn": "Arduino: Install Teensy Core",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Arduino: Upload Body",
            "type": "shell",
            "command": "arduino-cli",
            "args": [
                "--config-file",
                "${workspaceFolder}/.vscode/arduino-cli.yaml",
                "upload",
                "-p",
                "/dev/ttyACM0",
                "--fqbn",
                "teensy:avr:teensy40:usb=serial,speed=600,opt=o2std,keys=en-us",
                "${workspaceFolder}/src/drivers/body"
            ],
            "dependsOn": "Arduino: Compile Body",
            "problemMatcher": []
        }
    ]
}
