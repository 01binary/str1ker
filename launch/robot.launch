<launch>
  <!-- Serial bridge to arms -->
  <include file="$(find str1ker)/launch/arms.launch" />

  <!-- Serial bridge to main board -->
  <include file="$(find str1ker)/launch/main.launch" />

  <!-- ROS control stack -->
  <include file="$(find str1ker)/launch/controllers.launch" />

  <!-- Robot controller -->
  <node
    name="robot"
    pkg="str1ker"
    type="robot"
    required="true"
    output="screen"
  />

</launch>
